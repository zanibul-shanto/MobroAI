# ==========================================
# .NET Core & Minimal API Ignore List
# ==========================================

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio / IDE specific files
.vs/
.vscode/
*.user
*.userosscache
*.sln.docstates
*.suo
*.userprefs
*.workspace

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if necessary however generally it will be regenerated when restoring packages.
# project.lock.json
# project.assets.json

# Local Configuration & Secrets
# Ignore local environment settings that might contain database passwords or API keys
appsettings.Development.json
appsettings.local.json
*.secret.json

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Others
*.swp
*.*~
project.lock.json
.core/